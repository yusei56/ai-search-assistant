# Domain whose DNS A/AAAA record points to THIS server.
# Caddy uses it to auto-provision a Let's Encrypt TLS certificate.
PUBLIC_DOMAIN=search.cd-web.org

# Full public https URL (usually https://$PUBLIC_DOMAIN).
# Baked into the frontend bundle at build time as NEXT_PUBLIC_API_BASE.
PUBLIC_URL=https://search.cd-web.org
