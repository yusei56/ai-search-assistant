# ── Source site (WordPress REST API) ──────────────────────────────
WP_BASE_URL=https://test-site.141154.cd-web.org
WP_API_PATH=/wp-json/wp/v2
WP_POST_TYPES=pages,posts

# ── Index storage ─────────────────────────────────────────────────
INDEX_DIR=data/index

# ── Embeddings: bge-m3 (default) | openai | hash ──────────────────
# Backend "bge-m3" = the local sentence-transformers route. Pick the model:
#   BAAI/bge-m3            multilingual (EN/CN), best quality, ~2.3GB download
#   BAAI/bge-small-en-v1.5 English-only, light (~130MB), fast — great for this
#                          (English) site; used as the reliable default here
# hash = dependency-free fallback for quick smoke tests (no download)
EMBEDDING_BACKEND=bge-m3
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Only used when EMBEDDING_BACKEND=openai:
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=        # defaults to LLM_BASE_URL
# EMBEDDING_API_KEY=         # defaults to LLM_API_KEY

# ── LLM for AI Overview (OpenAI-compatible) ───────────────────────
# DeepSeek example shown; swap base_url/model for GPT-4o or a gateway.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# ── Retrieval ─────────────────────────────────────────────────────
TOP_K=8
PAGE_SIZE=10

# ── CORS (comma-separated, or *) ──────────────────────────────────
CORS_ORIGINS=*
